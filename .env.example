# Local Docker default; see docs/local-postgres.md.
DATABASE_URL="postgres://moonday:moonday@localhost:5433/moonday"

DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"

ANTHROPIC_API_KEY=""
GROQ_API_KEY=""

DEFAULT_AI_PROVIDER="groq"
DEFAULT_AI_MODEL="llama-3.3-70b-versatile"

CLAUDE_MODEL="claude-3-5-sonnet-latest"

APP_NAME="MOONDAY"
APP_ENV="development"

ENABLE_MEMORY_EXTRACTION="true"
ENABLE_VECTOR_SEARCH="true"
ENABLE_VOICE_FEATURES="true"
ENCRYPTION_KEY=""

# Optional local-first speech output. Start with `bun run tts:up`.
KOKORO_TTS_URL="http://127.0.0.1:8880"
KOKORO_TTS_VOICE="af_sarah"
# Local CPU inference can take longer for large replies. Range: 5000–120000 ms.
KOKORO_TTS_TIMEOUT_MS="60000"

# Web Search API Keys (Tavily or Brave Search)
TAVILY_API_KEY=""
BRAVE_SEARCH_API_KEY=""
SEARXNG_BASE_URL="http://localhost:8080"
